      "parameters": {
        "jsCode": "return items.map((item) => {\n  const j = item.json;\n\n  const clean = (s) =>\n    String(s || \"\")\n      .replace(/[\\s\\u200B-\\u200D\\uFEFF]/g, \"\")\n      .toLowerCase();\n\n  const findValue = (keywordGroups, fallback = \"-\") => {\n    const keys = Object.keys(j);\n    for (const key of keys) {\n      const ck = clean(key);\n      const matched = keywordGroups.some((group) =>\n        group.every((kw) => ck.includes(clean(kw)))\n      );\n      if (matched) {\n        const v = j[key];\n        if (v !== undefined && v !== null && String(v).trim() !== \"\") {\n          return String(v).trim();\n        }\n      }\n    }\n    return fallback;\n  };\n\n  const fullname = findValue([[\"ชื่อ\"], [\"นามสกุล\"]], \"-\");\n  const company = findValue([[\"บริษัท\"], [\"หน่วยงาน\"]], \"-\");\n  const phone = findValue([[\"เบอร์\", \"โทร\"], [\"โทรศัพท์\"], [\"เบอร์โทร\"]], \"-\");\n  const itemName = findValue([[\"รายชื่อ\", \"อุปกรณ์\"], [\"อุปกรณ์\"]], \"-\");\n  const quantity = findValue([[\"จำนวน\", \"เบิก\"], [\"จำนวน\"]], \"-\");\n  const emailUser = findValue([[\"email\"], [\"อีเมล\"]], \"-\");\n  const reason = findValue([[\"เหตุผล\", \"เบิก\"], [\"เหตุผล\"]], \"-\");\n\n  let requestDate = findValue([[\"ประทับเวลา\"], [\"วันที่\"], [\"timestamp\"]], \"-\");\n  const serial = Number(requestDate);\n  if (!Number.isNaN(serial) && serial > 1000) {\n    const excelEpoch = new Date(1899, 11, 30);\n    const dt = new Date(excelEpoch.getTime() + serial * 86400000);\n    requestDate = dt.toLocaleString(\"th-TH\");\n  }\n\n  const status = findValue([[\"สถานะ\", \"คำขอ\"], [\"สถานะ\"]], \"รออนุมัติ\");\n\n  j.mailToAdmin = \"sakkarat.tai@gmail.com\"; // เปลี่ยนเป็นเมลแอดมินจริงได้\n  j.mailSubjectAdmin = \"มีคำขอเบิกใหม่ รออนุมัติ\";\n  j.mailBodyAdmin =\n`มีคำขอเบิกใหม่เข้าระบบ\n\nวันที่: ${requestDate}\nชื่อ-นามสกุล: ${fullname}\nบริษัท/หน่วยงาน: ${company}\nเบอร์โทร: ${phone}\nรายการอุปกรณ์: ${itemName}\nจำนวนที่เบิก: ${quantity}\nอีเมลผู้ขอ: ${emailUser}\nเหตุผลการเบิก: ${reason}\nสถานะคำขอ: ${status}\n\nกรุณาเข้าเว็บ Admin เพื่ออนุมัติ`;\n\n  return item;\n});"
      },
