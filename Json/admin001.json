    {
      "parameters": {
        "jsCode": "return items.map((item) => {\n  const j = item.json;\n\n  const clean = (s) =>\n    String(s || \"\")\n      .replace(/[\\s\\u200B-\\u200D\\uFEFF]/g, \"\")\n      .toLowerCase();\n\n  const findValue = (keywordGroups, fallback = \"-\") => {\n    const keys = Object.keys(j);\n    for (const key of keys) {\n      const ck = clean(key);\n      const matched = keywordGroups.some((group) =>\n        group.every((kw) => ck.includes(clean(kw)))\n      );\n      if (matched) {\n        const v = j[key];\n        if (v !== undefined && v !== null && String(v).trim() !== \"\") {\n          return String(v).trim();\n        }\n      }\n    }\n    return fallback;\n  };\n\n  const fullname = findValue([[\"ชื่อ\"], [\"นามสกุล\"]], \"-\");\n  const company = findValue([[\"บริษัท\"], [\"หน่วยงาน\"]], \"-\");\n  const phone = findValue([[\"เบอร์\", \"โทร\"], [\"โทรศัพท์\"], [\"เบอร์โทร\"]], \"-\");\n  const emailUser = findValue([[\"email\"]], \"-\");\n  const itemName = findValue([[\"รายการ\", \"อุปกรณ์\"], [\"อุปกรณ์\"]], \"-\");\n  const quantity = findValue([[\"จำนวน\"]], \"-\");\n  const assetTag = findValue([[\"asset\", \"tag\"], [\"เลขเครื่อง\"]], \"-\");\n\n  // วันที่คืน\n  let returnDate = findValue([[\"ประทับเวลา\"], [\"วันที่\", \"คืน\"], [\"วันที่\"]], \"-\");\n  const serial = Number(returnDate);\n  if (!Number.isNaN(serial) && serial > 1000) {\n    const excelEpoch = new Date(1899, 11, 30);\n    const dt = new Date(excelEpoch.getTime() + serial * 86400000);\n    returnDate = dt.toLocaleString(\"th-TH\");\n  }\n\n  const status = findValue([[\"สถานะ\"], [\"คำขอ\"]], \"รอตรวจรับ\");\n\n  // แจ้งเฉพาะ admin\n  j.mailToAdmin = \"sakkarat.tai@gmail.com\"; // เปลี่ยนเป็นเมล admin จริงถ้าต้องการ\n  j.mailSubjectAdmin = \"มีคำขอคืน Laptop ใหม่\";\n  j.mailBodyAdmin =\n`มีคำขอคืนอุปกรณ์ใหม่\n\nวันที่คืน: ${returnDate}\nชื่อ-นามสกุล: ${fullname}\nบริษัท/หน่วยงาน: ${company}\nเบอร์โทร: ${phone}\nอีเมลผู้คืน: ${emailUser}\nรายการอุปกรณ์: ${itemName}\nจำนวนที่คืน: ${quantity}\nเลขเครื่อง (Asset Tag): ${assetTag}\nสถานะ: ${status}\n\nกรุณาเข้าหน้า Admin เพื่อตรวจรับรายการคืน`;\n\n  return item;\n});\n\n\n"
      },
